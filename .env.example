# Newsletter Configuration
# Get your API key from: https://app.convertkit.com/account_settings/advanced_settings
CONVERTKIT_API_KEY=your_convertkit_api_key_here

# Get your form ID from the ConvertKit form URL or dashboard
CONVERTKIT_FORM_ID=your_form_id_here

# Google Tag Manager — wrapper for GA4 + future pixels (FB, LinkedIn, etc.)
# 1. Create container at https://tagmanager.google.com → copy ID (format: GTM-XXXXXXX)
# 2. Inside GTM UI: add GA4 Configuration tag, set trigger = Custom Event "consent_granted"
# 3. Set this env var on Vercel + .env.local for local dev
NEXT_PUBLIC_GTM_ID=

# IndexNow — instant indexing ping for Bing/Yandex/Seznam
# 1. Generate UUID: openssl rand -hex 16
# 2. Save same value to: NEXT_PUBLIC_INDEXNOW_KEY=<uuid> AND public/<uuid>.txt (file content = the uuid)
# 3. The .txt file proves ownership when API call is made
NEXT_PUBLIC_INDEXNOW_KEY=

# Search Console verification tokens (optional — get from search.google.com/search-console)
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=

# Optional: Vercel Analytics (already configured)
# No additional env vars needed for basic analytics
